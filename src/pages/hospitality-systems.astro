---
import Base from "../layouts/Base.astro";

const ladder = [
  {
    index: "01",
    name: "Fit check",
    price: "free – 15 minutes",
    body: "A short call to work out whether your venue is a fit. No pitch – if I can't help, I'll say so and point you somewhere useful.",
  },
  {
    index: "02",
    name: "Operations audit",
    price: "$300–600",
    body: "A 90-minute walkthrough of how your venue actually runs, followed by an Operations System Map – where the numbers live, where the manual work is, and the three to five changes worth making first.",
  },
  {
    index: "03",
    name: "Build",
    price: "$1.5k–4k, fixed scope",
    body: "One focused system, built and shipped – a daily control panel that pulls your POS, bookings, and accounting into one view, or an automation that removes a recurring manual job.",
  },
  {
    index: "04",
    name: "Retainer",
    price: "$400–800/mo",
    body: "The system stays maintained, plus one small improvement a month and async support when something comes up.",
  },
];
---

<Base
  title="Hospitality operations systems – Marriott Systems"
  description="Custom operational systems for independent Brisbane restaurants – pulling POS, bookings, accounting, and rostering into one place. Audits from $300, builds from $1.5k."
>
  <section class="hero container" aria-labelledby="hero-heading">
    <p class="section-label">
      <span aria-hidden="true">01 / </span>hospitality systems
    </p>
    <h1 id="hero-heading" class="hero__headline">
      The dashboard your POS should have.
    </h1>
    <p class="hero__lede">
      I build small, custom operational systems that pull a restaurant's existing tools – POS,
      bookings, accounting, and rostering – into one place, so owners can see what is actually
      happening and stop doing manual work.
    </p>
    <p class="hero__meta mono">
      <span>independent venues</span>
      <span aria-hidden="true">·</span>
      <span>1–5 locations</span>
      <span aria-hidden="true">·</span>
      <span>brisbane</span>
    </p>
  </section>

  <section class="ladder container" aria-labelledby="ladder-heading">
    <p class="section-label ladder__label">
      <span aria-hidden="true">02 / </span>how it works
    </p>
    <h2 id="ladder-heading" class="visually-hidden">The offer, step by step</h2>

    <ol class="ladder__list">
      {ladder.map((step) => (
        <li class="ladder__item">
          <header class="ladder__header">
            <p class="ladder__index mono" aria-hidden="true">{step.index}</p>
            <h3 class="ladder__name">{step.name}</h3>
            <p class="ladder__price mono">{step.price}</p>
          </header>
          <p class="ladder__body">{step.body}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="proof container" aria-labelledby="proof-heading">
    <p class="section-label">
      <span aria-hidden="true">03 / </span>proof
    </p>
    <h2 id="proof-heading" class="proof__title">Built and running today.</h2>
    <p class="proof__body">
      A Brisbane pizzeria runs its end-of-service numbers on a system I built – daily sales,
      wages, COGS, and profitability across daily, weekly, monthly, and financial-year views,
      with the owner entering the day's figures in under two minutes.
    </p>
    <p class="proof__body">
      I'm a final-year software engineering student at UQ, and I take on two to three venues a
      semester – enough to do the work properly, not enough to become an agency.
    </p>
  </section>

  <section class="contact container" aria-labelledby="contact-heading">
    <p class="section-label">
      <span aria-hidden="true">04 / </span>get in touch
    </p>
    <h2 id="contact-heading" class="contact__title">Start with a fit check.</h2>
    <p class="contact__body">
      Fifteen minutes, free, no pitch. If your venue also needs its website fixed, that's a
      separate offer – <a href="https://web.jacobmarriott.com">audits and rebuilds here</a>.
    </p>
    <p class="contact__cta-row">
      <a class="contact__cta" href="https://cal.com/jacobem1836/20-min-intro" target="_blank" rel="noopener noreferrer">
        book a fit check <span aria-hidden="true">→</span>
      </a>
      <a class="contact__cta contact__cta--ghost" href="mailto:hello@jacobmarriott.com">
        hello@jacobmarriott.com
      </a>
    </p>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(5rem, 3rem + 8vw, 9rem) clamp(3rem, 2rem + 4vw, 5rem);
    display: grid;
    gap: var(--space-8);
  }

  .hero__headline {
    font-size: clamp(2.25rem, 1.4rem + 4.5vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 700;
    max-width: 18ch;
  }

  .hero__lede {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 58ch;
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    font-size: var(--text-xs);
    text-transform: lowercase;
    color: var(--color-text-dim);
  }

  .ladder {
    display: grid;
    gap: var(--space-12);
  }

  .ladder__label {
    color: var(--color-accent-muted);
  }

  .ladder__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-8);
  }

  .ladder__item {
    display: grid;
    gap: var(--space-3);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .ladder__item:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .ladder__header {
    display: grid;
    gap: var(--space-1);
  }

  .ladder__index {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
  }

  .ladder__name {
    font-size: var(--text-xl);
    font-weight: 600;
  }

  .ladder__price {
    font-size: var(--text-xs);
    color: var(--color-accent-muted);
    text-transform: lowercase;
  }

  .ladder__body {
    color: var(--color-text-muted);
    max-width: 62ch;
  }

  @media (min-width: 48rem) {
    .ladder__item {
      grid-template-columns: 12rem minmax(0, 1fr);
      gap: var(--space-4) clamp(1.5rem, -1rem + 8vw, 5rem);
      align-items: start;
    }

    .ladder__body {
      grid-column: 2;
      grid-row: 1;
    }
  }

  .proof,
  .contact {
    display: grid;
    gap: var(--space-6);
  }

  .proof__title,
  .contact__title {
    font-size: var(--text-2xl);
  }

  .proof__body,
  .contact__body {
    color: var(--color-text-muted);
    max-width: 58ch;
  }

  .contact__cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .contact__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-mono);
    text-transform: lowercase;
    color: var(--color-accent);
    background: var(--color-accent-bg);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 0.5em 0.9em;
    transition: background var(--duration-fast) var(--ease-out-expo);
  }

  .contact__cta:hover,
  .contact__cta:focus-visible {
    background: var(--color-accent);
    color: var(--color-bg);
    border-bottom-color: var(--color-accent);
  }

  .contact__cta--ghost {
    background: transparent;
    border-color: var(--color-border-strong);
    color: var(--color-text-muted);
  }

  .contact__cta--ghost:hover,
  .contact__cta--ghost:focus-visible {
    background: var(--color-bg-raised);
    color: var(--color-text);
  }
</style>
