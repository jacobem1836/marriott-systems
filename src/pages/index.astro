---
import Base from "../layouts/Base.astro";

interface Venture {
  index: string;
  kind: string;
  title: string;
  body: string;
  href: string;
  cta: string;
  external: boolean;
  flagship?: boolean;
}

const ventures: Venture[] = [
  {
    index: "01",
    kind: "product – flagship",
    title: "Brain Console",
    body: "A business-wide AI brain – persistent memory, tool execution, and one place that actually knows your company. Every employee gets an AI that answers in your voice, from your knowledge, with the sources attached.",
    href: "https://console.jacobmarriott.com",
    cta: "see brain console",
    external: true,
    flagship: true,
  },
  {
    index: "02",
    kind: "product – early access",
    title: "dAIly",
    body: "A voice-first morning brief – your email, calendar, Slack, and messages, synthesised, prioritised, and spoken to you before you open a single app.",
    href: "https://getdaily.dev",
    cta: "get early access",
    external: true,
  },
  {
    index: "03",
    kind: "service",
    title: "AI systems consulting",
    body: "Personalised AI systems for professionals and business owners – structured Claude Code environments, custom skills, knowledge graphs, and automation, tailored to how you actually work.",
    href: "https://jacobmarriott.com/consult",
    cta: "work with jacob",
    external: true,
  },
  {
    index: "04",
    kind: "service",
    title: "Hospitality websites",
    body: "Website audits and rebuilds for Brisbane restaurants, cafes, and bars – finding where a venue loses customers online, then fixing it.",
    href: "https://web.jacobmarriott.com",
    cta: "see the offer",
    external: true,
  },
  {
    index: "05",
    kind: "service",
    title: "Hospitality operations systems",
    body: "Custom operational systems that pull a venue's existing tools – POS, bookings, accounting, and rostering – into one place, so owners can see what is actually happening.",
    href: "/hospitality-systems",
    cta: "see the work",
    external: false,
  },
  {
    index: "06",
    kind: "founder",
    title: "Jacob Marriott",
    body: "Software engineer and founder – agentic AI, full-stack systems, and a portfolio of shipped work. Studying software engineering at UQ.",
    href: "https://jacobmarriott.com",
    cta: "about jacob",
    external: true,
  },
];
---

<Base>
  <section class="hero container" aria-labelledby="hero-heading">
    <p class="section-label">
      <span aria-hidden="true">01 / </span>company
    </p>
    <h1 id="hero-heading" class="hero__headline">
      Marriott Systems
      <span class="hero__headline-soft">AI products and operational systems, built in Brisbane.</span>
    </h1>
    <p class="hero__lede">
      Marriott Systems is the company behind <a href="https://console.jacobmarriott.com">Brain Console</a>,
      <a href="https://getdaily.dev">dAIly</a>, and a consulting practice that builds AI and operational
      systems for real businesses – founded and run by
      <a href="https://jacobmarriott.com">Jacob Marriott</a>.
    </p>
    <p class="hero__meta mono">
      <span>brisbane, au</span>
      <span class="hero__meta-dot" aria-hidden="true">·</span>
      <span>est. 2026</span>
      <span class="hero__cursor" aria-hidden="true">▍</span>
    </p>
  </section>

  <section class="ventures container" aria-labelledby="ventures-heading">
    <p class="section-label ventures__label">
      <span aria-hidden="true">02 / </span>ventures
    </p>
    <h2 id="ventures-heading" class="visually-hidden">Ventures and services</h2>

    <ol class="ventures__list">
      {ventures.map((v) => (
        <li class:list={["ventures__item", { "ventures__item--flagship": v.flagship }]}>
          <header class="ventures__header">
            <p class="ventures__index mono" aria-hidden="true">{v.index}</p>
            <h3 class="ventures__title">
              {v.external ? (
                <a class="ventures__title-link" href={v.href} target="_blank" rel="noopener noreferrer">
                  {v.title}
                  <span class="ventures__title-arrow" aria-hidden="true">↗</span>
                  <span class="visually-hidden">(opens in a new tab)</span>
                </a>
              ) : (
                <a class="ventures__title-link" href={v.href}>
                  {v.title}
                  <span class="ventures__title-arrow" aria-hidden="true">→</span>
                </a>
              )}
            </h3>
            <p class="ventures__kind mono">{v.kind}</p>
          </header>
          <div class="ventures__detail">
            <p class="ventures__body">{v.body}</p>
            <p class="ventures__cta-row">
              {v.external ? (
                <a class="ventures__cta" href={v.href} target="_blank" rel="noopener noreferrer">
                  {v.cta} <span aria-hidden="true">→</span>
                </a>
              ) : (
                <a class="ventures__cta" href={v.href}>
                  {v.cta} <span aria-hidden="true">→</span>
                </a>
              )}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </section>
</Base>

<style>
  .hero {
    padding-block: clamp(6rem, 4rem + 10vw, 12rem) clamp(3rem, 2rem + 4vw, 6rem);
    display: grid;
    gap: var(--space-8);
  }

  .hero__headline {
    font-size: clamp(2.75rem, 1.8rem + 5.5vw, 6rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 700;
    max-width: 14ch;
  }

  .hero__headline-soft {
    display: block;
    font-size: clamp(1rem, 0.85rem + 0.8vw, 1.375rem);
    color: var(--color-text-muted);
    font-weight: 400;
    letter-spacing: var(--tracking-tight);
    margin-top: var(--space-4);
    font-family: var(--font-sans);
  }

  .hero__lede {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 58ch;
    line-height: var(--leading-prose);
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-3);
    font-size: var(--text-xs);
    text-transform: lowercase;
    color: var(--color-text-muted);
  }

  .hero__meta-dot {
    color: var(--color-text-dim);
  }

  .hero__cursor {
    display: inline-block;
    color: var(--color-accent);
    margin-left: 0.15em;
    animation: cursor-blink 1.1s steps(1, end) infinite;
  }

  @keyframes cursor-blink {
    0%, 50%      { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__cursor {
      animation: none;
      opacity: 1;
    }
  }

  @media (min-width: 48rem) {
    .hero__lede,
    .hero__meta {
      padding-left: clamp(0rem, -2rem + 10vw, 8rem);
    }
  }

  .ventures {
    display: grid;
    gap: var(--space-12);
  }

  .ventures__label {
    color: var(--color-accent-muted);
  }

  .ventures__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-12);
  }

  .ventures__item {
    display: grid;
    gap: var(--space-4);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .ventures__item:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .ventures__item--flagship .ventures__kind {
    color: var(--color-accent);
  }

  .ventures__header {
    display: grid;
    gap: var(--space-2);
  }

  .ventures__index {
    font-size: var(--text-xs);
    color: var(--color-text-dim);
  }

  .ventures__title {
    font-size: clamp(1.5rem, 1.1rem + 1.6vw, 2.25rem);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    line-height: 1.15;
  }

  .ventures__title-link {
    color: inherit;
    border-bottom: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .ventures__title-link:hover,
  .ventures__title-link:focus-visible {
    color: var(--color-accent);
    border-bottom: 0;
  }

  .ventures__title-arrow {
    font-size: 0.65em;
    color: var(--color-text-dim);
    transition: color var(--duration-fast) var(--ease-out-expo),
                transform var(--duration-fast) var(--ease-out-expo);
  }

  .ventures__title-link:hover .ventures__title-arrow,
  .ventures__title-link:focus-visible .ventures__title-arrow {
    color: var(--color-accent);
    transform: translate(0.1em, -0.1em);
  }

  .ventures__kind {
    font-size: var(--text-xs);
    color: var(--color-accent-muted);
    text-transform: lowercase;
  }

  .ventures__detail {
    display: grid;
    gap: var(--space-4);
  }

  .ventures__body {
    font-size: var(--text-base);
    max-width: 62ch;
    color: var(--color-text);
  }

  .ventures__cta-row {
    margin: 0;
  }

  .ventures__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-mono);
    text-transform: lowercase;
    color: var(--color-accent);
  }

  .ventures__cta span {
    transition: transform var(--duration-fast) var(--ease-out-expo);
  }

  .ventures__cta:hover span,
  .ventures__cta:focus-visible span {
    transform: translateX(3px);
  }

  @media (min-width: 48rem) {
    .ventures__item {
      grid-template-columns: 12rem minmax(0, 1fr);
      gap: var(--space-8) clamp(1.5rem, -1rem + 8vw, 5rem);
      align-items: start;
    }

    .ventures__header {
      grid-column: 1;
      padding-top: 0.35rem;
    }

    .ventures__detail {
      grid-column: 2;
    }

    .ventures__body {
      font-size: var(--text-lg);
      line-height: var(--leading-prose);
    }

    .ventures__title {
      font-size: var(--text-xl);
    }
  }
</style>
